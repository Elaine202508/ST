# =========================================================================
# SillyTavern-Termux 腳本環境變數設定
# =========================================================================

# 核心選單與安裝腳本的本地儲存路徑
MENU_PATH="$HOME/Menu.sh"
INSTALL_PATH="$HOME/Install.sh"
ENV_PATH="$HOME/.env"

# 字體與啟動相關設定
FONT_PATH="$HOME/.termux/font.ttf"
START_MODE="1"
